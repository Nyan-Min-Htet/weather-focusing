{
  "version": 2,
  "builds": [
    {
      "src": "src/api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "maxDuration": 10
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/api/index.py" },
    { "src": "/city/(.*)", "dest": "src/api/index.py" },
    { "src": "/(.*)", "dest": "src/api/index.py" }
  ]
}
